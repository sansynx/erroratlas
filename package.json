{
  "name": "@sansynx/erroratlas",
  "version": "0.2.0",
  "private": false,
  "type": "module",
  "description": "Hosted ErrorAtlas MCP client and local debugging memory tools for coding agents.",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "erroratlas": "dist/cli/index.js",
    "erroratlas-mcp": "dist/mcp/server.js"
  },
  "files": [
    "dist/cli",
    "dist/mcp",
    "dist/shared",
    "templates",
    "README.md"
  ],
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "cf-types": "wrangler types src/worker/worker-configuration.d.ts",
    "prepack": "npm run build",
    "mcp": "tsx src/mcp/server.ts",
    "cli": "tsx src/cli/index.ts"
  },
  "keywords": [
    "mcp",
    "debugging",
    "coding-agents",
    "supermemory"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.0.12",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "wrangler": "^4.24.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sansynx/erroratlas.git"
  },
  "bugs": {
    "url": "https://github.com/sansynx/erroratlas/issues"
  },
  "homepage": "https://github.com/sansynx/erroratlas#readme",
  "author": ""
}
