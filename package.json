{
  "name": "@sansynx/erroratlas",
  "version": "0.1.4",
  "private": false,
  "type": "module",
  "description": "Hosted ErrorAtlas MCP client and local debugging memory tools for coding agents.",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "erroratlas": "dist/cli/index.js",
    "erroratlas-mcp": "dist/mcp/server.js"
  },
  "files": [
    "dist",
    "templates",
    "public",
    "README.md"
  ],
  "scripts": {
    "sync:assets": "node scripts/sync-assets.mjs",
    "dev": "npm run sync:assets && wrangler dev",
    "deploy": "wrangler deploy",
    "build": "npm run sync:assets && tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build",
    "mcp": "tsx src/mcp/server.ts",
    "cli": "tsx src/cli/index.ts"
  },
  "keywords": [
    "mcp",
    "debugging",
    "coding-agents",
    "supermemory"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "latest",
    "@types/node": "^24.0.12",
    "playwright": "^1.61.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "wrangler": "^4.24.0"
  }
}
