{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "erroratlas",
  "main": "src/worker/index.ts",
  "compatibility_date": "2026-07-09",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "vars": {
    "APP_NAME": "ErrorAtlas"
  }
}
