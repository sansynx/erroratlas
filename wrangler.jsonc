{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "erroratlas",
  "main": "src/worker/index.ts",
  "compatibility_date": "2026-07-10",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "run_worker_first": true
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "vars": {
    "APP_NAME": "ErrorAtlas"
  }
}
